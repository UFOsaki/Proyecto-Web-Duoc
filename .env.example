# .env.example — Sharingan Comics
# ==================================
# Copia este archivo como .env o usa variables de entorno del sistema.
# NUNCA subir .env ni application-local.yml al repositorio.
#
# Cumplimiento: ISO 27001 A.9.4.3 (gestión de secretos)
# ==================================

# ─── Oracle Autonomous Database ───────────────────────────────────────────────
ORACLE_DB_TNS_ALIAS=sharingan_medium
TNS_ADMIN=C:/ruta/a/tu/oracle-wallet
ORACLE_DB_USERNAME=ADMIN
ORACLE_DB_PASSWORD=tu_password_oracle_aqui

# ─── JWT Local (auth propia) ───────────────────────────────────────────────────
# Mínimo 256 bits (32+ caracteres) para HMAC-SHA256
JWT_SECRET=cambia-este-secreto-por-uno-seguro-de-minimo-32-caracteres

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.cl/developers/panel
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-de-mercadopago

# URLs de redirección Mercado Pago
MP_SUCCESS_URL=http://localhost:8080/payment-success.html
MP_FAILURE_URL=http://localhost:8080/payment-failure.html
MP_PENDING_URL=http://localhost:8080/payment-pending.html
MP_NOTIFICATION_URL=https://tu-render-url.onrender.com/api/payments/webhook

# ─── Clerk (Identidad externa, 2FA/MFA, Google login) ────────────────────────
# Aplicación Clerk: tender-coral-13 (derivado de la publishable key)
# Dashboard: https://dashboard.clerk.com
#
# clerk.enabled activa la integración. En false solo JWT local funciona.
CLERK_ENABLED=true

# Issuer y JWKS URL (derivados de la publishable key — NO son secretos)
CLERK_ISSUER=https://tender-coral-13.clerk.accounts.dev
CLERK_JWKS_URL=https://tender-coral-13.clerk.accounts.dev/.well-known/jwks.json

# SECRET KEY: Solo necesaria para llamadas server-to-server (Clerk Management API).
# Si no usas la Management API, dejar vacío.
# NUNCA usar en frontend — NUNCA subir al repositorio.
CLERK_SECRET_KEY=sk_test_tu_secret_key_aqui

# ─── Frontend (NO es variable de entorno del backend) ─────────────────────────
# CLERK_PUBLISHABLE_KEY va en src/main/resources/static/assets/JS/config.js
# Ya configurada: pk_test_dGVuZGVyLWNvcmFsLTEzLmNsZXJrLmFjY291bnRzLmRldiQ
# Es seguro en frontend (es pública por diseño de Clerk).
